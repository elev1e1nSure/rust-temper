<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="RustPatch.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RustPatch">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Styles/BindComboBoxStyle.xaml" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <!-- Explicit (non-theme) brushes so "darker" doesn't depend on which system theme is active. -->
            <SolidColorBrush x:Key="AppDarkSurfaceBrush" Color="#1A1A1A" />
            <SolidColorBrush x:Key="AppDarkSurfaceHoverBrush" Color="#262626" />
            <SolidColorBrush x:Key="AppDarkSurfacePressedBrush" Color="#101010" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
